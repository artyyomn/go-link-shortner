<!DOCTYPE html>
<html>
	<head>

		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">

		<title>Link Shortener</title>

		<style>
		@import url('https://fonts.googleapis.com/css2?family=Datatype:wght@100..900&display=swap');
		@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@100..900&display=swap');

		*{
			box-sizing:border-box;
			margin:0;
			padding:0;
			font-family: "Datatype","Montserrat",sans-serif;
		}

		html,body{
			height:100%;
			overflow:hidden;
		}

		body{
			min-height:100vh;
			display:flex;
			justify-content:center;
			align-items:center;
			padding:20px;

			/*
			background:linear-gradient(
				0deg,
				#000,#1a1a1a,#2b2b2b,#111,#3a3a3a,#000
			);
			*/
			background: #1a1a1a;
			background-size:400% 400%;
			/*animation:gradientMove 20s ease infinite;*/
		}

		@keyframes gradientMove{
			0%{background-position:0% 50%}
			50%{background-position:100% 50%}
			100%{background-position:0% 50%}
		}

		#container{
			width:100%;
			max-width:500px;
			padding:32px 26px;
			border-radius:22px;

			background:rgba(255,255,255,0.05);
			/*backdrop-filter:blur(22px);*/
			border:1px solid rgba(255,255,255,0.2);

			/*
			box-shadow:
				0 10px 40px rgba(0,0,0,0.7),
			inset 0 1px rgba(255,255,255,0.15);
			*/

			display:flex;
			flex-direction:column;
			gap:14px;
		}

		h2{
			color:#f5f5f5;
			font-size:1.3rem;
			font-weight:500;
			text-align:center;
			letter-spacing:1px;
			margin-bottom: 0.5rem;
		}

		/* input */

		#link{
			width:100%;
			padding:14px;
			border-radius:14px;
			border:1px solid rgba(255,255,255,0.18);
			background:rgba(255,255,255,0.08);
			color:#fff;
			font-size:0.95rem;
			transition:.25s;
		}

		#link::placeholder{
			color:#bbb;
			font-family:"Datatype";
		}

		#link:focus{
			outline:none;
			border:1px solid rgba(255,255,255,0.4);
			background:rgba(255,255,255,0.12);
		}

		/* buttons */

		button{
			padding:12px 16px;
			border-radius:12px;
			border:1px solid rgba(255,255,255,0.2);
			background:rgba(255,255,255,0.12);
			color:#fff;
			font-size:1rem;
			cursor:pointer;
			transition:.2s;
			letter-spacing:2px;
		}

		button:hover{
			background:rgba(255,255,255,0.2);
			transform:translateY(-1px);
		}

		button:active{
			transform:scale(.96);
		}

		/* result */

		#shortLink{
			margin-top:10px;
			display:flex;
			justify-content:center;
			width:100%;
		}

		.resultRow{
			display:flex;
			width:100%;
			gap:8px;
			align-items:center;
		}

		/* textbox */

		.linkToCopy{
			flex:1;
			min-width:0;
			padding:12px;
			border-radius:12px;
			border:1px solid rgba(255,255,255,0.18);
			background:rgba(255,255,255,0.08);
			color:#fff;
			font-size:0.9rem;
			outline:none;
		}

		/* copy button */

		.copyBtn{
			display:flex;
			justify-content:center;
			align-items:center;
			width:42px;
			height:42px;
			font-size:18px;
			border-radius:10px;
			padding:0;
			flex-shrink:0;
		}

		.copyBtn svg{
			width:18px;
			height:18px;
			pointer-events:none;
		}

		/* responsive */

		@media (max-width:480px){

			#container{
				padding:26px 20px;
			}

			h2{
				font-size:1.1rem;
			}

			#link{
				font-size:0.9rem;
				padding:12px;
			}

			button{
				font-size:0.85rem;
				padding:11px;
			}

			/* allow wrap on very small screens */

			.resultRow{
				flex-wrap:wrap;
			}

			.copyBtn{
				width:100%;
				height:38px;
			}
		}
		</style>
	</head>

	<body>

		<div id="container">
			<h2>Link-Shortner</h2>
			<input type="text" placeholder="paste-url-here" id="link">
			<button onclick="submitLink()">CUT</button>
			<div id="shortLink"></div>
		</div>

		<script>

			const linkInput = document.getElementById("link")
			const shortLinkContainer = document.getElementById("shortLink")

			function sanitizeLink(link){
				const str = String(link).trim()
				if(str.length === 0) return ""
				return str
			}

			async function submitLink(){

				try{

					const goodLink = sanitizeLink(linkInput.value)

					if(!goodLink) return

					const res = await fetch("https://go-link-shortner.onrender.com/",{
						method:"POST",
						headers:{
							"Content-Type":"application/json"
						},
						body:JSON.stringify({
							long:goodLink,
							short:""
						})
					})

					const data = await res.json()

					const wrapper = document.createElement("div")
					wrapper.className = "resultRow"

					const returnedLink = document.createElement("input")
					returnedLink.className = "linkToCopy"
					returnedLink.readOnly = true
					returnedLink.value = "go-link-shortner.onrender.com/" + data

					const copyBtn = document.createElement("button")
					copyBtn.className = "copyBtn"

					copyBtn.innerHTML = `
					<svg xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<rect x="9" y="9" width="13" height="13" rx="2"></rect>
					<path d="M5 15H4a2 2 0 0 1-2-2V4
					a2 2 0 0 1 2-2h9
					a2 2 0 0 1 2 2v1"></path>
					</svg>
					`

					wrapper.appendChild(returnedLink)
					wrapper.appendChild(copyBtn)

					shortLinkContainer.innerHTML = ""
					shortLinkContainer.appendChild(wrapper)

					copyBtn.addEventListener("click", async ()=>{
						await navigator.clipboard.writeText(returnedLink.value)
						copyBtn.innerHTML = `
						<svg xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="3"
						stroke-linecap="round"
						stroke-linejoin="round">
						<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
						`
					})
				}catch(err){
					console.error("fetch error",err)
				}
			}
		</script>
	</body>
</html>
