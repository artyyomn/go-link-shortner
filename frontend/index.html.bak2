<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Link Shortener</title>

<style>

@import url('https://fonts.googleapis.com/css2?family=Datatype:wght@100..900&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@100..900&display=swap');

*{
    box-sizing:border-box;
    margin:0;
    padding:0;
    font-family:"Datatype","Montserrat",sans-serif;
}

html,body{
    height:100%;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
    background:#1a1a1a;
}

/* container */

#container{
    width:100%;
    max-width:500px;
    padding:32px 26px;
    border-radius:22px;

    background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.2);

    display:flex;
    flex-direction:column;
    gap:16px;
}

/* heading */

h2{
    color:#f5f5f5;
    font-size:1.35rem;
    font-weight:500;
    text-align:center;
    letter-spacing:1px;
}

/* helper text */

.sub{
    font-size:0.75rem;
    color:#aaa;
    text-align:center;
    letter-spacing:1px;
}

/* input */

.inputWrap{
    display:flex;
    flex-direction:column;
    gap:6px;
}

label{
    font-size:0.7rem;
    letter-spacing:2px;
    color:#999;
}

#link{
    width:100%;
    padding:14px;
    border-radius:14px;
    border:1px solid rgba(255,255,255,0.18);
    background:rgba(255,255,255,0.08);
    color:#fff;
    font-size:0.95rem;
    transition:.2s;
}

#link::placeholder{
    color:#777;
}

#link:focus{
    outline:none;
    border:1px solid rgba(255,255,255,0.4);
    background:rgba(255,255,255,0.12);
}

/* button */

button{
    padding:13px;
    border-radius:12px;
    border:1px solid rgba(255,255,255,0.2);
    background:rgba(255,255,255,0.12);
    color:#fff;
    font-size:0.95rem;
    cursor:pointer;
    transition:.18s;
    letter-spacing:2px;
}

button:hover:not(:disabled){
    background:rgba(255,255,255,0.2);
    transform:translateY(-1px);
}

button:active:not(:disabled){
    transform:scale(.96);
}

button:disabled{
    opacity:.35;
    cursor:not-allowed;
}

/* result */

#shortLink{
    min-height:46px;
    display:flex;
    align-items:center;
}

.resultRow{
    display:flex;
    width:100%;
    gap:8px;
}

.linkToCopy{
    flex:1;
    padding:12px;
    border-radius:12px;
    border:1px solid rgba(255,255,255,0.18);
    background:rgba(255,255,255,0.08);
    color:#fff;
    font-size:0.9rem;
}

.copyBtn{
    width:44px;
    height:44px;
    border-radius:10px;
    display:flex;
    align-items:center;
    justify-content:center;
}

.copyBtn svg{
    width:18px;
    height:18px;
}

/* feedback */

.msg{
    font-size:0.75rem;
    letter-spacing:1px;
    color:#888;
    text-align:center;
}

/* loading */

.loading{
    opacity:.6;
    pointer-events:none;
}

/* responsive */

@media(max-width:480px){

    #container{
        padding:26px 20px;
    }

    .resultRow{
        flex-direction:column;
    }

    .copyBtn{
        width:100%;
        height:40px;
    }
}

</style>
</head>

<body>

<div id="container">

<h2>Link-Shortner</h2>
<div class="sub">fast minimal url cutter</div>

<div class="inputWrap">
<label>PASTE URL</label>
<input
type="text"
id="link"
placeholder="https://example.com/very/long/link"
/>
</div>

<button id="submitBtn">CUT</button>

<div id="shortLink"></div>

<div id="msg" class="msg"></div>

</div>

<script>

const linkInput = document.getElementById("link")
const submitBtn = document.getElementById("submitBtn")
const shortLinkContainer = document.getElementById("shortLink")
const msg = document.getElementById("msg")

function sanitizeLink(link){
    const str = String(link).trim()
    return str
}

function setLoading(state){

    if(state){
        submitBtn.textContent = "CUTTING..."
        submitBtn.classList.add("loading")
        submitBtn.disabled = true
    }
    else{
        submitBtn.textContent = "CUT"
        submitBtn.classList.remove("loading")
        submitBtn.disabled = false
    }
}

function validate(url){

    try{
        new URL(url)
        return true
    }
    catch{
        return false
    }
}

async function submitLink(){

    const goodLink = sanitizeLink(linkInput.value)

    if(!goodLink){
        msg.textContent = "enter a url"
        return
    }

    if(!validate(goodLink)){
        msg.textContent = "invalid url format"
        return
    }

    msg.textContent = ""

    try{

        setLoading(true)

        const res = await fetch(
            "https://go-link-shortner.onrender.com/",
            {
                method:"POST",
                headers:{
                    "Content-Type":"application/json"
                },
                body:JSON.stringify({
                    long:goodLink,
                    short:""
                })
            }
        )

        const data = await res.json()

        const wrapper = document.createElement("div")
        wrapper.className = "resultRow"

        const returnedLink = document.createElement("input")
        returnedLink.className = "linkToCopy"
        returnedLink.readOnly = true
        returnedLink.value =
            "https://go-link-shortner.onrender.com/" + data

        returnedLink.onclick = () => returnedLink.select()

        const copyBtn = document.createElement("button")
        copyBtn.className = "copyBtn"

        copyBtn.innerHTML = iconCopy()

        wrapper.appendChild(returnedLink)
        wrapper.appendChild(copyBtn)

        shortLinkContainer.innerHTML = ""
        shortLinkContainer.appendChild(wrapper)

        copyBtn.onclick = async ()=>{

            await navigator.clipboard.writeText(returnedLink.value)

            copyBtn.innerHTML = iconCheck()

            msg.textContent = "copied"

            setTimeout(()=>{
                copyBtn.innerHTML = iconCopy()
                msg.textContent = ""
            },1500)
        }

    }
    catch(e){

        msg.textContent = "network error"

    }
    finally{

        setLoading(false)

    }

}

/* icons */

function iconCopy(){
return `
<svg xmlns="http://www.w3.org/2000/svg"
viewBox="0 0 24 24"
fill="none"
stroke="currentColor"
stroke-width="2">
<rect x="9" y="9" width="13" height="13" rx="2"/>
<path d="M5 15H4a2 2 0 0 1-2-2V4
a2 2 0 0 1 2-2h9
a2 2 0 0 1 2 2v1"/>
</svg>`
}

function iconCheck(){
return `
<svg xmlns="http://www.w3.org/2000/svg"
viewBox="0 0 24 24"
fill="none"
stroke="currentColor"
stroke-width="3">
<polyline points="20 6 9 17 4 12"/>
</svg>`
}

/* events */

submitBtn.onclick = submitLink

linkInput.addEventListener("input",()=>{

    submitBtn.disabled =
        linkInput.value.trim().length === 0

})

linkInput.addEventListener("keydown",e=>{

    if(e.key === "Enter"){
        submitLink()
    }

})

submitBtn.disabled = true

</script>

</body>
</html>
